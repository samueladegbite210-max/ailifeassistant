<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LifeAI - AI Life Assistant</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body class="bg-gray-50 dark:bg-gray-950 min-h-screen">
    <!-- Login Screen -->
    <div id="login-screen" class="max-w-md mx-auto p-6 pt-20">
        <div class="text-center mb-10">
            <i class="fas fa-brain text-6xl text-emerald-600"></i>
            <h1 class="text-4xl font-bold mt-4">LifeAI</h1>
            <p class="text-gray-600">Global AI Life Assistant</p>
        </div>
        <div class="bg-white dark:bg-gray-800 p-8 rounded-3xl shadow">
            <input id="username" type="text" placeholder="Your Name" class="w-full p-4 rounded-2xl border mb-4">
            <button onclick="login()" class="w-full py-4 bg-emerald-600 text-white rounded-3xl font-medium">Start Using LifeAI</button>
        </div>
    </div>

    <!-- Main App -->
    <div id="app-screen" class="hidden">
        <div class="max-w-2xl mx-auto p-4">
            <header class="bg-emerald-700 p-6 rounded-3xl text-white mb-6">
                <div class="flex justify-between items-center">
                    <div class="flex items-center gap-3">
                        <i class="fas fa-brain text-4xl"></i>
                        <div>
                            <h1 class="text-3xl font-bold">LifeAI</h1>
                            <p id="user-greeting" class="text-emerald-100"></p>
                        </div>
                    </div>
                    <button onclick="showSettings()" class="text-2xl">⚙️</button>
                </div>
            </header>

            <div class="bg-emerald-600 text-white p-6 rounded-3xl mb-6">
                <div class="flex justify-between">
                    <div>
                        <p class="text-sm opacity-75">Current Streak</p>
                        <p id="streak" class="text-4xl font-bold">0 days 🔥</p>
                    </div>
                    <button onclick="newInsight()" class="px-6 py-3 bg-white/20 rounded-2xl">New Insight</button>
                </div>
                <p id="ai-text" class="italic mt-4"></p>
            </div>

            <div id="main-content"></div>
        </div>
    </div>

    <script>
        let currentUser = "";
        let streak = parseInt(localStorage.getItem('streak')) || 0;

        function login() {
            currentUser = document.getElementById('username').value.trim() || "Friend";
            localStorage.setItem('lifeai_user', currentUser);
            document.getElementById('login-screen').classList.add('hidden');
            document.getElementById('app-screen').classList.remove('hidden');
            initApp();
        }

        function initApp() {
            document.getElementById('user-greeting').textContent = `Welcome, ${currentUser}`;
            updateStreak();
            newInsight();
            switchTab(0);
        }

        function updateStreak() {
            document.getElementById('streak').textContent = `${streak} days 🔥`;
        }

        function newInsight() {
            const insights = ["You're making great progress!", "Small daily actions lead to big results.", "Consistency beats perfection.", "Review your goals this week."];
            document.getElementById("ai-text").textContent = `"${insights[Math.floor(Math.random()*insights.length)]}"`;
        }

        function showSettings() {
            alert("Settings:\n\n1. Change Name\n2. Reset Data\n3. Export Data\n\nMore features coming soon!");
        }

        // Add more tabs and features here...
        function switchTab(n) {
            const content = document.getElementById('main-content');
            content.innerHTML = `<p class="text-center py-10 text-xl">Tab ${n} coming soon...</p>`;
        }

        // Auto login
        if (localStorage.getItem('lifeai_user')) {
            currentUser = localStorage.getItem('lifeai_user');
            document.getElementById('login-screen').classList.add('hidden');
            document.getElementById('app-screen').classList.remove('hidden');
            initApp();
        }
    </script>
</body>
</html>
